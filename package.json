{
  "name": "@ai-by-design/primitiv",
  "version": "1.2.0",
  "description": "The reconciliation layer for agentic design systems. Sits above Figma, your codebase, and Storybook — resolves conflicts, exposes a single source of truth via MCP.",
  "main": "dist/index.js",
  "bin": {
    "primitiv": "dist/cli.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "prepare": "tsc",
    "dev": "ts-node src/index.ts",
    "start": "node dist/index.js",
    "lint": "eslint src/**/*.ts"
  },
  "keywords": [
    "design-system",
    "mcp",
    "agentic",
    "primitives",
    "tokens",
    "figma",
    "storybook",
    "cursor",
    "claude-code"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/AI-by-design/primitiv.git"
  },
  "bugs": {
    "url": "https://github.com/AI-by-design/primitiv/issues"
  },
  "homepage": "https://github.com/AI-by-design/primitiv#readme",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.22.0",
    "glob": "^13.0.6",
    "chalk": "^5.0.0",
    "ora": "^9.3.0"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "@types/node": "^25.5.0",
    "ts-node": "^10.0.0"
  }
}
